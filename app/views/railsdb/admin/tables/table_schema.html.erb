<div class='level'>
  <div class='level-left'>
    <div class='level-item'>
      <p class='title'> <%= @table.capitalize %> schema </p>
    </div>
  </div>

  <div class='level-right'>
    <div class='level-item'>
      <%= link_to 'Explore table data', table_data_path(@table), class: 'button is-primary' %>
    </div>

    <div class='level-item'>
      <%= render 'railsdb/admin/shared/search', placeholder: "Search in #{@table} schema" %>
    </div>
  </div>
</div>



<div class="table-container">
  <table class="table is-fullwidth is-striped is-hoverable">
    <thead>
      <tr>
        <% @columns.first.as_json.each do |key, value| %>
          <th><%= key %></th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% @columns.as_json.each do |column| %>
        <tr>
          <% column.values.each do |value| %>
            <td> <%= value %>  </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @foreign_keys.any? %>
  <div class="table-container">
    <table class="table is-fullwidth is-striped is-hoverable">
      <caption>Foreign keys</caption>
      <thead>
        <tr>
          <% @foreign_keys.first.as_json.each do |key, value| %>
            <th><%= key %></th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% @foreign_keys.as_json.each do |column| %>
          <tr>
            <% column.values.each do |value| %>
              <td> <%= value %>  </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @foreign_keys.any? %>
  <div class="table-container">
    <table class="table is-fullwidth is-striped is-hoverable">
      <caption>Indexes</caption>
      <thead>
        <tr>
          <% @indexes.first.as_json.each do |key, value| %>
            <th><%= key %></th>
          <% end %>
        </tr>
      </thead>

      <tbody>
        <% @indexes.as_json.each do |column| %>
          <tr>
            <% column.values.each do |value| %>
              <td> <%= value %>  </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
