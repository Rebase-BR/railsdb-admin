          <% end %>
        </tr>
      </thead>

      <tbody>
        <% @indexes.as_json.each do |column| %>
          <tr>
            <% column.values.each do |value| %>
              <td> <%= value %>  </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
