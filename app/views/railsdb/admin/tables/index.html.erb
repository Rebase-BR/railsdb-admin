<%= render 'layouts/railsdb/admin/control_pane', sort_by: @tables.first.keys.map(&:capitalize) %>

<table class="table is-fullwidth is-striped is-hoverable">
  <thead>
      <tr>
          <th>Table Name</th>
          <th>Records</th>
          <th>Columns</th>
          <th>Actions</th>
      </tr>
  </thead>
  <tbody>
    <% @tables.each do |table| %>
      <tr class='table-row'>
        <td class='is-vcentered'><span><%= table[:name].capitalize %></span></td>
        <td class='is-vcentered'><%= table[:records] %></td>
        <td class='is-vcentered'><%= table[:columns] %></td>
        <td class='is-vcentered'>
          <div class='buttons'>
            <%= link_to 'Schema', table_schema_path(table[:name]), class: 'button is-info' %>
            <%= link_to 'Data', table_data_path(table[:name]), class: 'button is-primary' %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
