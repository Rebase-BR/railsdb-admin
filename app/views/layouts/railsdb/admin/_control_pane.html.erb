<nav class="level">
  <!-- Left side -->
  <div class="level-left">
    <div class="level-item">
      <div class="field is-grouped">
        <div class="control">

          <div class="select">
            <select id="sortField">
              <% sort_by.each do |item| %>
                <option value="<%= item %>"> <%= "Sort by #{item}" %></option>
              <% end %>
            </select>
          </div>

          <button id="sortDirection" class="button is-warning"> 
            <span class="icon">
              <span>&#8645</span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Right side -->
  <div class="level-right">
    <div class="level-item">
      <div class="field has-addons">
        <p class="control">
          <input class="input" type="text" placeholder="Search tables" />
        </p>
        <p class="control">
          <button class="button is-warning">Search</button>
        </p>
      </div>
    </div>
  </div>
</nav>
